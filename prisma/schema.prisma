generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A single agent's 50x50 farm, addressed by UUID for save/load. worldX/worldY
// place this farm on the shared, ever-expanding world grid (see
// src/farmGen/worldPlacement.ts) so farms can be located relative to their
// neighbors on the world map.
model Farm {
  id        String   @id @default(uuid())
  name      String?
  width     Int      @default(50)
  height    Int      @default(50)
  worldX    Int      @default(0)
  worldY    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tiles      Tile[]
  agent      Agent?
  actionLogs ActionLog[]
  inventory  InventoryItem[]

  @@unique([worldX, worldY])
}

// A registered agent. Authenticates to the MCP tools using its id plus the
// plaintext apiSecret handed back once at registration time — only a salted
// hash of that secret is ever stored. There is no on-farm position: the
// agent has "god mode" visibility over its whole farm and acts on tiles by
// explicit (x, y) coordinate rather than moving an avatar around.
model Agent {
  id            String   @id @default(uuid())
  name          String?
  apiSecretHash String
  farmId        String   @unique
  farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  eventLogs     EventLog[]
  bugReports    BugReport[]
}

// One cell of a Farm's grid. Terrain, debris, and crop are separate layers
// on the same coordinate. A tile only ever has debris OR a crop, never both
// — planting requires debris to be cleared first. Trees are a third,
// mutually-exclusive "growing thing" alongside crop/debris (see
// src/game/trees.ts): treeType is set only on a tree's own center tile,
// fruitType only on one of its 8 surrounding footprint tiles, and
// blockedByTree on all 8 footprint tiles permanently (renders "#" there
// whenever fruitType/debris aren't overriding it). cropStage is reused for
// whichever of cropType/treeType/fruitType is actually set on a given
// tile, since exactly one of them is ever non-null at a time.
model Tile {
  id            Int       @id @default(autoincrement())
  farmId        String
  farm          Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  x             Int
  y             Int
  // TerrainType: "DIRT" (SQLite has no native enum support).
  terrain       String    @default("DIRT")
  // DebrisType: "NONE" | "WEED" | "ROCK" | "WILTED" (SQLite has no native enum support).
  debris        String    @default("NONE")
  // CropType key from src/game/crops.ts (e.g. "carrot"), or null if unplanted.
  cropType      String?
  cropStage     Int       @default(0)
  plantedAt     DateTime?
  // TreeType key from src/game/trees.ts — set only on a tree's center tile.
  treeType      String?
  // TreeType key — a tree's fruit is the same species as the tree itself.
  // Set only on one of a tree's 8 footprint tiles while a fruit is ripening/ripe.
  fruitType     String?
  // True on all 8 footprint tiles of a planted tree, forever (trees are
  // permanent) — renders "#" and blocks till/plant whenever fruitType and
  // debris=="WILTED" aren't overriding it.
  blockedByTree Boolean   @default(false)
  // Back-reference to the owning tree's center tile (set on the center
  // tile too, pointing at itself, for symmetry).
  treeCenterX   Int?
  treeCenterY   Int?
  updatedAt     DateTime  @updatedAt

  @@unique([farmId, x, y])
  @@index([farmId])
}

// One agent tool call against a farm (till/plant/harvest/sell/buy_seeds),
// success or fail. Pruned to the most recent 50 rows per farm right after
// each insert (see recordAction in src/mcp/tools.ts) — this is a rolling
// activity feed for the web viewer, not a permanent audit log. x/y are null
// for actions with no tile coordinate (e.g. market trades).
model ActionLog {
  id        Int      @id @default(autoincrement())
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  action    String
  x         Int?
  y         Int?
  message   String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([farmId, createdAt])
}

// Every MCP tool call an agent makes — read-only inspections as well as
// mutations — kept permanently (unlike ActionLog, this is never pruned).
// Exists for debugging and metrics, not for the live web viewer, so it's
// queried directly (sqlite3/Prisma Studio) rather than through an app route.
model EventLog {
  id          Int      @id @default(autoincrement())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Denormalized alongside agentId so events stay queryable per-farm without
  // a join, the same tradeoff ActionLog makes.
  farmId      String
  tool        String
  // JSON-encoded tool input args (SQLite has no native Json type via Prisma).
  input       String
  success     Boolean
  message     String
  durationMs  Int
  createdAt   DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([farmId, createdAt])
  @@index([tool, createdAt])
}

// A bug report an agent filed via the report_bug MCP tool. Always persisted
// here regardless of whether filing a GitHub issue (src/github.ts) succeeded
// — githubIssueUrl/githubIssueNumber are null if that call failed (bad/
// missing token, GitHub API hiccup, etc.), so a report is never lost just
// because the GitHub side-effect didn't go through.
model BugReport {
  id                String   @id @default(uuid())
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Denormalized alongside agentId, same tradeoff EventLog makes.
  farmId            String
  message           String
  githubIssueUrl    String?
  githubIssueNumber Int?
  createdAt         DateTime @default(now())

  @@index([agentId])
  @@index([farmId])
}

// Per-farm counts of seeds, harvested crops, and debris cleared from tiles.
// itemType is a CropType key (e.g. "carrot") for seeds/produce, or a
// lowercased DebrisType ("weed"/"rock") for what tilling turns up. No cap on
// quantity — inventory is unbounded/"infinite" for now, see src/game/inventory.ts.
model InventoryItem {
  id       Int    @id @default(autoincrement())
  farmId   String
  farm     Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  itemType String
  quantity Int    @default(0)

  @@unique([farmId, itemType])
}
